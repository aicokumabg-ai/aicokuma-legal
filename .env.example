# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789

# ── TikTok 자격증명 (수동 로그인 사용 시 비워도 됨) ──────────────────────────
TIKTOK_USERNAME=
TIKTOK_PASSWORD=

# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/bot.db

# ═══════════════════════════════════════════════════════════════════════════════
# Chrome 연결 방식 (3가지 중 1개 선택)
# ═══════════════════════════════════════════════════════════════════════════════

# ★ 방법 1 (권장): 기존 Chrome에 CDP로 연결
#   → Chrome을 아래 명령으로 실행하세요:
#     Windows: "C:\Program Files\Google\Chrome\Application\chrome.exe" --remote-debugging-port=9222
#     Mac:     /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --remote-debugging-port=9222
#     Linux:   google-chrome --remote-debugging-port=9222
#   → TikTok에 로그인된 상태로 Chrome이 떠 있으면 봇이 그 세션을 그대로 사용
CHROME_DEBUG_PORT=9222

# 방법 2: Chrome이 꺼진 상태에서 기존 프로필 직접 사용
#   Windows: CHROME_USER_DATA_DIR=C:\Users\사용자명\AppData\Local\Google\Chrome\User Data
#   Mac:     CHROME_USER_DATA_DIR=/Users/사용자명/Library/Application Support/Google/Chrome
#   Linux:   CHROME_USER_DATA_DIR=/home/사용자명/.config/google-chrome
CHROME_USER_DATA_DIR=
CHROME_PROFILE=Default

# 방법 3: 새 Chromium (세션을 별도 저장 — 처음 실행 시 로그인 필요)
BROWSER_HEADLESS=false
SESSION_DIR=./data/tiktok_session

# ── Anti-Bot Delays (초) ──────────────────────────────────────────────────────
REPLY_DELAY_MIN=30
REPLY_DELAY_MAX=300
DM_DELAY_MIN=60
DM_DELAY_MAX=180
POLL_INTERVAL_MIN=300
POLL_INTERVAL_MAX=900

# ── Rate Limiting ─────────────────────────────────────────────────────────────
SAME_USER_COOLDOWN=86400
