# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 쉼표로 구분된 허용 사용자 ID (본인만 접근)
TELEGRAM_ALLOWED_USERS=123456789

# ── TikTok ───────────────────────────────────────────────────────────────────
TIKTOK_USERNAME=your_tiktok_username
TIKTOK_PASSWORD=your_tiktok_password

# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=/app/data/bot.db

# ── Browser ───────────────────────────────────────────────────────────────────
# false = 실제 창 표시 (봇 탐지 회피에 유리)
BROWSER_HEADLESS=false
SESSION_DIR=/app/data/tiktok_session

# ── Anti-Bot Delays (초) ──────────────────────────────────────────────────────
REPLY_DELAY_MIN=30
REPLY_DELAY_MAX=300
DM_DELAY_MIN=60
DM_DELAY_MAX=180
POLL_INTERVAL_MIN=300
POLL_INTERVAL_MAX=900

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# 동일 유저에게 재발송 금지 기간 (초, 기본 24시간)
SAME_USER_COOLDOWN=86400
